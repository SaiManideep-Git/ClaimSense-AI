# Server Configuration
PORT=5000
HOST_URL=http://localhost:5000

# MongoDB Configuration
# Leave blank to fallback to local mongodb://localhost:27017/claimsense
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/claimsense?retryWrites=true&w=majority

# AI / LLM Configuration
# At least one key is needed for actual vision extraction. If both are blank, the system automatically uses mock extraction from test_cases.json
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# File Storage Configuration (Cloudinary)
# Leave blank to fallback to saving uploads locally on disk under server/uploads/
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
